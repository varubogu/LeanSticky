{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://varubogu.github.io/LeanSticky/schema/v001/schema.json",
  "title": "LeanSticky Schema Bundle v001",
  "description": "Shared JSON Schema definitions for LeanSticky YAML files.",
  "$defs": {
    "schema_version": {
      "type": "string",
      "const": "v001"
    },
    "path_string": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": ["system", "ja", "en"]
    },
    "locale_message": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "messages": {
      "type": "object",
      "description": "Map of message keys to Japanese and English strings.",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_.-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/locale_message"
      }
    },
    "window_position": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "window_size": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "window_state": {
      "type": "object",
      "required": ["position", "size", "maximized"],
      "properties": {
        "position": {
          "$ref": "#/$defs/window_position"
        },
        "size": {
          "$ref": "#/$defs/window_size"
        },
        "maximized": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "history_config": {
      "type": "object",
      "properties": {
        "max_snapshots_per_note": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "required": ["schema_version", "note_roots"],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "locale": {
          "$ref": "#/$defs/locale"
        },
        "note_roots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/path_string"
          }
        },
        "autosave_delay_ms": {
          "type": "integer",
          "minimum": 1,
          "default": 1500
        },
        "history": {
          "$ref": "#/$defs/history_config"
        }
      },
      "additionalProperties": false
    },
    "session_open_window": {
      "type": "object",
      "required": ["root", "note_id", "position", "size", "maximized"],
      "properties": {
        "root": {
          "$ref": "#/$defs/path_string"
        },
        "note_id": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "$ref": "#/$defs/window_position"
        },
        "size": {
          "$ref": "#/$defs/window_size"
        },
        "maximized": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "session": {
      "type": "object",
      "required": ["schema_version", "management_window", "open_windows"],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "management_window": {
          "$ref": "#/$defs/window_state"
        },
        "open_windows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/session_open_window"
          }
        }
      },
      "additionalProperties": false
    },
    "note": {
      "type": "object",
      "required": [
        "schema_version",
        "id",
        "title",
        "content",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
