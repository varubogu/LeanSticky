{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://varubogu.github.io/LeanSticky/schema/v001/schema.json",
  "title": "LeanSticky Schema Bundle v001",
  "description": "Shared JSON Schema definitions for LeanSticky YAML files.",
  "$defs": {
    "schema_version": {
      "type": "string",
      "const": "v001"
    },
    "locale": {
      "type": "string",
      "enum": ["system", "ja", "en"]
    },
    "locale_message": {
      "type": "object",
      "required": ["ja", "en"],
      "properties": {
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "messages": {
      "type": "object",
      "description": "Map of message keys to Japanese and English strings.",
      "propertyNames": {
        "pattern": "^[a-z0-9][a-z0-9_.-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/locale_message"
      }
    },
    "window_position": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "window_size": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "window_state": {
      "type": "object",
      "properties": {
        "position": {
          "$ref": "#/$defs/window_position"
        },
        "size": {
          "$ref": "#/$defs/window_size"
        },
        "maximized": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "history_config": {
      "type": "object",
      "properties": {
        "max_snapshots_per_note": {
          "type": "integer",
          "minimum": 1
        },
        "recent_keep_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "long_term_interval_minutes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "required": ["schema_version", "note_roots"],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "locale": {
          "$ref": "#/$defs/locale"
        },
        "note_roots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "autosave_delay_ms": {
          "type": "integer",
          "minimum": 1,
          "default": 1500
        },
        "history": {
          "$ref": "#/$defs/history_config"
        }
      },
      "additionalProperties": false
    },
    "note": {
      "type": "object",
      "required": [
        "schema_version",
        "id",
        "content",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schema_version"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "always_on_top": {
          "type": "boolean"
        },
        "window": {
          "$ref": "#/$defs/window_state"
        }
      },
      "additionalProperties": false
    }
  }
}
